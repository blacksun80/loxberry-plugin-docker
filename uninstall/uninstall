#!/bin/bash

# LoxBerry uninstall script for the Docker plugin.
#
# This file lives in  uninstall/uninstall  and is executed AS ROOT at the
# very end of the plugin uninstallation (NOT on update). Its job is to undo
# everything that postroot.sh set up.
#
# FULL REMOVAL: Because Docker is the base platform, this removes the whole
# Docker stack - the Docker engine, the Portainer container, the Docker apt
# repository/key and the docker group. That also destroys ALL OTHER
# containers/images on the system (e.g. a UniFi controller running in
# Docker). This is intended: uninstalling the Docker plugin means the whole
# Docker stack goes away. Uninstall your Docker-based apps first, this
# plugin last.
#
# For logging print to STDOUT using <INFO>/<OK>/<WARNING>/<ERROR> tags.

echo "<INFO> Docker plugin uninstall - starting full removal of Docker and Portainer."

# --- 1. Remove the Portainer container (created by postroot.sh) ---
if [ -x /usr/bin/docker ]
then
	echo "<INFO> Removing Portainer container..."
	docker rm --force portainer > /dev/null 2>&1
fi

# --- 2. Stop and disable the Docker daemon ---
echo "<INFO> Stopping Docker service..."
systemctl stop docker.socket > /dev/null 2>&1
systemctl stop docker > /dev/null 2>&1
systemctl disable docker > /dev/null 2>&1

# --- 3. Purge the Docker engine packages (installed via get.docker.com) ---
# Only purge packages that are actually installed. On older LoxBerry/Debian
# versions (LoxBerry 3 is not on Trixie) some of these - e.g. the buildx or
# compose plugins - may not exist. Passing an unknown package name to
# "apt-get purge" aborts the whole command and removes nothing, so we filter
# down to the installed set first via dpkg-query.
echo "<INFO> Removing Docker engine packages..."
export DEBIAN_FRONTEND=noninteractive
DOCKER_PKGS=$(dpkg-query -W -f='${Package}\n' docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin docker-ce-rootless-extras 2>/dev/null)
if [ -n "$DOCKER_PKGS" ]
then
	apt-get purge -y $DOCKER_PKGS > /dev/null 2>&1
fi
apt-get autoremove -y --purge > /dev/null 2>&1

# --- 4. Remove Docker data and the Portainer volume ---
echo "<INFO> Removing Docker data directories and Portainer volume..."
rm -rf /var/lib/docker
rm -rf /var/lib/containerd
rm -rf /opt/portainer

# --- 5. Remove the Docker apt repository and GPG key ---
echo "<INFO> Removing Docker apt repository and key..."
rm -f /etc/apt/sources.list.d/docker.list
rm -f /etc/apt/keyrings/docker.asc
rm -f /etc/apt/keyrings/docker.gpg
rm -f /usr/share/keyrings/docker-archive-keyring.gpg

# --- 6. Remove the docker group and loxberry's membership ---
echo "<INFO> Removing docker group membership..."
gpasswd -d loxberry docker > /dev/null 2>&1
groupdel docker > /dev/null 2>&1

# --- 7. Refresh apt so the removed repo disappears from the cache ---
apt-get update > /dev/null 2>&1

echo "<OK> Docker, Portainer and all related data have been removed."

# Exit with Status 0
exit 0
